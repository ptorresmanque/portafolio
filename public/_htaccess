# Cache static assets briefly; cache only Angular hashed JS/CSS for 1 year
<IfModule mod_expires.c>
  ExpiresActive On
  <FilesMatch "\.(js|css|woff2?|svg|png|jpe?g|webp|ico)$">
    ExpiresDefault "access plus 1 day"
  </FilesMatch>
  <FilesMatch "-[A-Z0-9]{6,}\.(js|css)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  # Static assets copied without hashes can change at the same URL
  <FilesMatch "\.(js|css|woff2?|svg|png|jpe?g|webp|ico)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Angular content-hashed bundles are immutable
  <FilesMatch "-[A-Z0-9]{6,}\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # index.html must always be fresh
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header unset ETag
  </FilesMatch>

  # Security headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# MIME types
<IfModule mod_mime.c>
  AddType application/xml .xml
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Disable directory listing
Options -Indexes

# Default start page
DirectoryIndex index.html
